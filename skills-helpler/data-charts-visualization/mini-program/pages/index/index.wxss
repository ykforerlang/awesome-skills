.page-shell {
  height: 100vh;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.title-card,
.preview-card,
.tabs-card,
.config-card {
  border: 2rpx solid rgba(58, 74, 69, 0.16);
  background: rgba(255, 251, 245, 0.86);
  box-shadow: 0 18rpx 48rpx rgba(70, 47, 23, 0.1);
  border-radius: 28rpx;
  backdrop-filter: blur(20rpx);
}

.title-card {
  padding: 28rpx;
}

.eyebrow {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #8d3f19;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1d2928;
}

.page-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5d6a67;
}

.page-note {
  margin-top: 18rpx;
  color: #5d6a67;
  font-size: 24rpx;
  line-height: 1.6;
}

.title-badge,
.section-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(191, 95, 47, 0.12);
  color: #8d3f19;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.preview-sticky {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-card {
  padding: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1d2928;
}

.preview-canvas {
  display: block;
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.72);
}

.tabs-card {
  padding: 12rpx;
}

.tabs-scroll {
  width: 100%;
  white-space: nowrap;
}

.tabs-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 12rpx;
}

.chart-tab {
  min-width: 132rpx;
  padding: 18rpx 24rpx;
  text-align: center;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  color: #465452;
  font-size: 26rpx;
  font-weight: 700;
}

.chart-tab.active {
  border-color: rgba(191, 95, 47, 0.48);
  background: linear-gradient(180deg, rgba(255, 249, 241, 0.96), rgba(248, 230, 212, 0.96));
  color: #8d3f19;
}

.config-scroll {
  flex: 1;
  min-height: 0;
}

.config-card {
  padding: 24rpx;
}

.config-card-last {
  margin-top: 20rpx;
  margin-bottom: 16rpx;
}

.form-section + .form-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(58, 74, 69, 0.08);
}

.form-section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1d2928;
}

.form-section-help {
  margin-top: 10rpx;
  color: #5d6a67;
  font-size: 22rpx;
  line-height: 1.6;
}

.field-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.field-card {
  width: calc(50% - 8rpx);
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 2rpx solid rgba(58, 74, 69, 0.1);
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #32413f;
}

.picker-value,
.field-input,
.field-textarea {
  width: 100%;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  color: #1d2928;
  font-size: 24rpx;
  line-height: 1.4;
}

.picker-value {
  min-height: 54rpx;
  display: flex;
  align-items: center;
}

.field-textarea {
  min-height: 116rpx;
}

.field-input-wrap {
  position: relative;
}

.field-input {
  padding-right: 58rpx;
}

.color-dot {
  position: absolute;
  top: 50%;
  right: 18rpx;
  width: 24rpx;
  height: 24rpx;
  margin-top: -12rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(29, 41, 40, 0.16);
.title-row {
  flex-wrap: wrap;
}
