.page-shell {
  height: 100vh;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.preview-card,
.tabs-card,
.config-card {
  border: 2rpx solid rgba(58, 74, 69, 0.16);
  background: rgba(255, 251, 245, 0.86);
  box-shadow: 0 18rpx 48rpx rgba(70, 47, 23, 0.1);
  border-radius: 28rpx;
  backdrop-filter: blur(20rpx);
}

.section-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(191, 95, 47, 0.12);
  color: #8d3f19;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.preview-head-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.preview-copy-button {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #bf5f2f;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
  box-shadow: 0 10rpx 24rpx rgba(191, 95, 47, 0.24);
}

.preview-sticky {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-card {
  padding: 22rpx 22rpx 20rpx;
}

.config-card {
  padding: 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1d2928;
}

.preview-stage-shell {
  margin-top: 10rpx;
  width: 100%;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding-bottom: 4rpx;
}

.preview-canvas-shell {
  border-radius: 20rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(246, 239, 228, 0.96)),
    linear-gradient(135deg, rgba(191, 95, 47, 0.08), rgba(111, 152, 141, 0.08));
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 16rpx 36rpx rgba(70, 47, 23, 0.08);
  flex: none;
}

.preview-canvas-shell .preview-canvas {
  display: block;
  width: 100%;
  height: 100%;
}

.preview-config-panel {
  margin-top: 4rpx;
  padding: 12rpx 14rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(250, 245, 238, 0.92));
}

.preview-config-layout {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 72rpx;
}

.preview-config-fixed-label {
  flex: none;
  font-size: 22rpx;
  font-weight: 800;
  color: #32413f;
  white-space: nowrap;
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(58, 74, 69, 0.08);
}

.preview-config-scroll {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.preview-config-row {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding-right: 10rpx;
}

.preview-config-group {
  flex: none;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  padding: 10rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 245, 0.9);
  border: 2rpx solid rgba(58, 74, 69, 0.08);
}

.preview-config-group-label {
  padding: 0 4rpx;
  font-size: 19rpx;
  font-weight: 700;
  color: #5d6a67;
  white-space: nowrap;
}

.preview-config-buttons {
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
}

.preview-config-button {
  min-width: 76rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  color: #465452;
  font-size: 19rpx;
  line-height: 1.3;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
}

.preview-config-button.active {
  border-color: rgba(191, 95, 47, 0.42);
  background: rgba(248, 230, 212, 0.96);
  color: #8d3f19;
}

.tabs-card {
  padding: 12rpx;
}

.tabs-scroll {
  width: 100%;
  white-space: nowrap;
}

.tabs-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 12rpx;
}

.chart-tab {
  min-width: 132rpx;
  padding: 18rpx 24rpx;
  text-align: center;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  color: #465452;
  font-size: 26rpx;
  font-weight: 700;
}

.chart-tab.active {
  border-color: rgba(191, 95, 47, 0.48);
  background: linear-gradient(180deg, rgba(255, 249, 241, 0.96), rgba(248, 230, 212, 0.96));
  color: #8d3f19;
}

.section-tabs-scroll {
  width: calc(100% - 56rpx);
  white-space: nowrap;
}

.section-tabs-shell {
  position: relative;
  width: 100%;
}

.section-tabs-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 12rpx;
}

.section-tab {
  min-width: 120rpx;
  padding: 14rpx 22rpx;
  text-align: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 2rpx solid rgba(58, 74, 69, 0.1);
  color: #4d5b58;
  font-size: 24rpx;
  font-weight: 700;
}

.section-tab.active {
  border-color: rgba(191, 95, 47, 0.42);
  background: rgba(248, 230, 212, 0.96);
  color: #8d3f19;
}

.config-shell {
  flex: 1;
  min-height: 0;
}

.config-card-last {
  height: 100%;
  margin-top: 0;
  margin-bottom: 0;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.form-section + .form-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(58, 74, 69, 0.08);
}

.tab-panel-section {
  margin-top: 0;
}

.config-panel-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 14rpx;
}

.form-section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1d2928;
}

.form-section-help {
  margin-top: 10rpx;
  color: #5d6a67;
  font-size: 22rpx;
  line-height: 1.6;
}

.field-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.field-card {
  box-sizing: border-box;
  width: calc((100% - 16rpx) / 2);
  min-width: 0;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 2rpx solid rgba(58, 74, 69, 0.1);
}

.field-card-wide {
  width: 100%;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #32413f;
}

.picker-value,
.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  color: #1d2928;
  font-size: 24rpx;
  line-height: 1.4;
}

.picker-value {
  min-height: 65rpx;
  height: 65rpx;
  display: flex;
  align-items: center;
}

.field-input {
  min-height: 65rpx;
  height: 65rpx;
}

.field-textarea {
  padding: 16rpx 18rpx;
  min-height: 116rpx;
}

.field-label,
.picker-value,
.field-input,
.field-textarea,
.color-picker-button {
  word-break: break-all;
}

.field-input-wrap {
  position: relative;
}

.switch-value {
  min-height: 65rpx;
  height: 65rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.color-picker-button {
  box-sizing: border-box;
  width: 100%;
  min-height: 65rpx;
  height: 65rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(58, 74, 69, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.palette-editor {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(58, 74, 69, 0.18);
  background: rgba(255, 255, 255, 0.72);
}

.palette-editor-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  flex-wrap: wrap;
}

.palette-editor-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #32413f;
}

.palette-editor-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.palette-action-button {
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(191, 95, 47, 0.12);
  color: #8d3f19;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.palette-swatches-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
}

.palette-swatch-button {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 999rpx;
  border: 2rpx solid rgba(29, 41, 40, 0.12);
}

.picker-popup-header {
  padding: 28rpx 32rpx 12rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #1d2928;
}
