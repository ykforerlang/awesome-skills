page {
  height: 100%;
  background:
    radial-gradient(circle at top left, rgba(239, 181, 110, 0.28), transparent 32%),
    radial-gradient(circle at top right, rgba(111, 152, 141, 0.22), transparent 34%),
    linear-gradient(180deg, #f6efe4 0%, #faf6ef 45%, #efe4d7 100%);
  color: #1d2928;
  font-family: "PingFang SC", "SF Pro Text", sans-serif;
}

view,
text,
scroll-view,
button,
input,
textarea,
switch,
picker,
canvas {
  box-sizing: border-box;
}
