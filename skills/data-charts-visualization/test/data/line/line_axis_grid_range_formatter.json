{
  "backgroundColor": "#fcfcfd",
  "title": {
    "text": "Axis And Grid Styling"
  },
  "legend": {
    "top": "top",
    "left": "right"
  },
  "grid": {
    "left": 90,
    "right": 40,
    "top": 90,
    "bottom": 80
  },
  "xAxis": {
    "type": "category",
    "name": "Month",
    "data": ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
    "nameTextStyle": {
      "fontSize": 11,
      "fontWeight": "bold",
      "color": "#334155"
    },
    "axisLabel": {
      "rotate": 25,
      "fontSize": 10,
      "color": "#475569"
    },
    "axisLine": {
      "show": true,
      "lineStyle": {
        "color": "#94a3b8"
      }
    },
    "splitLine": {
      "show": true,
      "lineStyle": {
        "type": "dotted",
        "width": 0.8,
        "color": "#e2e8f0"
      }
    }
  },
  "yAxis": {
    "type": "value",
    "name": "Sales",
    "min": 150,
    "max": 280,
    "nameTextStyle": {
      "fontSize": 11,
      "fontWeight": "bold",
      "color": "#334155"
    },
    "axisLabel": {
      "fontSize": 10,
      "color": "#0f172a",
      "formatter": "${value}"
    },
    "axisLine": {
      "show": true,
      "lineStyle": {
        "color": "#64748b"
      }
    },
    "splitLine": {
      "show": true,
      "lineStyle": {
        "type": "dashed",
        "width": 1.0,
        "color": "#cbd5e1",
        "opacity": 0.9
      }
    }
  },
  "series": [
    {
      "name": "Retail",
      "type": "line",
      "symbol": "circle",
      "lineStyle": {
        "width": 3,
        "color": "#0ea5e9",
        "type": "solid"
      },
      "itemStyle": {
        "color": "#0ea5e9"
      },
      "data": [180, 196, 210, 236, 248, 265]
    }
  ]
}
