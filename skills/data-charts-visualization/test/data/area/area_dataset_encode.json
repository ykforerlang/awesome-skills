{
  "title": {
    "text": "Area Dataset + Encode"
  },
  "legend": {
    "top": "top"
  },
  "dataset": {
    "source": [
      {"day": "Mon", "app": 120, "web": 90},
      {"day": "Tue", "app": 132, "web": 101},
      {"day": "Wed", "app": 101, "web": 84},
      {"day": "Thu", "app": 134, "web": 109},
      {"day": "Fri", "app": 190, "web": 120}
    ]
  },
  "xAxis": {
    "type": "category"
  },
  "yAxis": {
    "type": "value",
    "name": "Signups"
  },
  "series": [
    {
      "name": "App",
      "type": "line",
      "areaStyle": {
        "opacity": 0.3
      },
      "encode": {
        "x": "day",
        "y": "app"
      }
    },
    {
      "name": "Web",
      "type": "line",
      "areaStyle": {
        "opacity": 0.22
      },
      "encode": {
        "x": "day",
        "y": "web"
      }
    }
  ]
}
