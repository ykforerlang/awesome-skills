{
  "title": {
    "text": "Dataset Encode Dual Axis"
  },
  "legend": {
    "top": "top"
  },
  "dataset": {
    "source": [
      {"day": "Mon", "orders": 120, "revenue": 1800},
      {"day": "Tue", "orders": 132, "revenue": 1960},
      {"day": "Wed", "orders": 101, "revenue": 1710},
      {"day": "Thu", "orders": 134, "revenue": 2150},
      {"day": "Fri", "orders": 190, "revenue": 2680}
    ]
  },
  "xAxis": {
    "type": "category"
  },
  "yAxis": [
    {
      "type": "value",
      "name": "Orders"
    },
    {
      "type": "value",
      "name": "Revenue"
    }
  ],
  "series": [
    {
      "name": "Orders",
      "type": "bar",
      "encode": {
        "x": "day",
        "y": "orders"
      }
    },
    {
      "name": "Revenue",
      "type": "line",
      "yAxisIndex": 1,
      "symbol": "triangle",
      "encode": {
        "x": "day",
        "y": "revenue"
      }
    }
  ]
}
