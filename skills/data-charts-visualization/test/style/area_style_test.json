{
  "backgroundColor": "#f8fafc",
  "title": {
    "textStyle": {
      "fontSize": 20,
      "fontWeight": "bold",
      "color": "#0f172a"
    }
  },
  "legend": {
    "top": "bottom",
    "left": "center",
    "textStyle": {
      "fontSize": 10,
      "color": "#334155"
    }
  },
  "grid": {
    "left": 80,
    "right": 40,
    "top": 90,
    "bottom": 70
  },
  "xAxis": {
    "axisLabel": {
      "rotate": 18,
      "color": "#475569"
    }
  },
  "series": [
    {
      "type": "line",
      "smooth": true,
      "lineStyle": {
        "width": 3.2
      },
      "areaStyle": {
        "opacity": 0.28
      },
      "label": {
        "show": true,
        "color": "#0f172a",
        "formatter": "{c}"
      }
    }
  ]
}
