{
  "backgroundColor": "#f8fafc",
  "title": {
    "textStyle": {
      "fontSize": 20,
      "fontWeight": "bold",
      "color": "#0f172a"
    }
  },
  "legend": {
    "top": "bottom",
    "left": "center",
    "textStyle": {
      "fontSize": 10,
      "color": "#334155"
    }
  },
  "grid": {
    "left": 80,
    "right": 40,
    "top": 90,
    "bottom": 70
  },
  "xAxis": {
    "axisLabel": {
      "rotate": 20,
      "color": "#475569"
    }
  },
  "yAxis": {
    "axisLabel": {
      "formatter": "{value}%"
    }
  },
  "series": [
    {
      "type": "line",
      "symbol": "triangle",
      "symbolSize": 7,
      "lineStyle": {
        "width": 3.5,
        "type": "dashed"
      },
      "label": {
        "show": true,
        "color": "#0f172a",
        "formatter": "{c}"
      }
    }
  ]
}
