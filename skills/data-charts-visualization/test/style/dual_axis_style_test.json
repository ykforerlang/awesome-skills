{
  "yAxis": [
    {
      "axisLabel": {
        "color": "#5470c6",
        "formatter": "{value}"
      }
    },
    {
      "axisLabel": {
        "color": "#ee6666",
        "formatter": "${value}"
      }
    }
  ],
  "series": [
    {
      "type": "bar",
      "itemStyle": {
        "opacity": 0.84,
        "borderColor": "#1d4ed8",
        "borderWidth": 1.0
      },
      "label": {
        "show": true,
        "formatter": "{c}"
      }
    },
    {
      "type": "line",
      "symbol": "diamond",
      "symbolSize": 6,
      "lineStyle": {
        "width": 3.2,
        "type": "dashed"
      },
      "label": {
        "show": true,
        "formatter": "{c}"
      }
    }
  ]
}
