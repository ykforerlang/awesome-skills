{
  "backgroundColor": "#f8fafc",
  "title": {
    "textStyle": {
      "fontSize": 20,
      "fontWeight": "bold",
      "color": "#0f172a"
    }
  },
  "legend": {
    "top": "bottom",
    "left": "center",
    "textStyle": {
      "fontSize": 10,
      "color": "#334155"
    }
  },
  "grid": {
    "left": 80,
    "right": 40,
    "top": 90,
    "bottom": 70
  },
  "yAxis": [
    {
      "axisLabel": {
        "color": "#5470c6",
        "formatter": "{value}"
      }
    },
    {
      "axisLabel": {
        "color": "#ee6666",
        "formatter": "${value}"
      }
    }
  ],
  "series": [
    {
      "type": "bar",
      "itemStyle": {
        "opacity": 0.84,
        "borderColor": "#1d4ed8",
        "borderWidth": 1.0
      },
      "label": {
        "show": true,
        "formatter": "{c}"
      }
    },
    {
      "type": "line",
      "symbol": "diamond",
      "symbolSize": 6,
      "lineStyle": {
        "width": 3.2,
        "type": "dashed"
      },
      "label": {
        "show": true,
        "formatter": "{c}"
      }
    }
  ]
}
