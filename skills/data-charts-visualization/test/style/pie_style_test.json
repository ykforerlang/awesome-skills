{
  "backgroundColor": "#f8fafc",
  "title": {
    "textStyle": {
      "fontSize": 20,
      "fontWeight": "bold",
      "color": "#0f172a"
    }
  },
  "legend": {
    "top": "bottom",
    "left": "right",
    "orient": "vertical",
    "textStyle": {
      "fontSize": 10,
      "color": "#334155"
    }
  },
  "series": [
    {
      "type": "pie",
      "radius": [
        "35%",
        "70%"
      ],
      "label": {
        "show": true,
        "position": "outside",
        "formatter": "{b} {d}%"
      },
      "selectedOffset": 14
    }
  ]
}
