{
  "backgroundColor": "#f8fafc",
  "title": {
    "textStyle": {
      "fontSize": 20,
      "fontWeight": "bold",
      "color": "#0f172a"
    }
  },
  "legend": {
    "top": "bottom",
    "left": "center",
    "textStyle": {
      "fontSize": 10,
      "color": "#334155"
    }
  },
  "grid": {
    "left": 80,
    "right": 40,
    "top": 90,
    "bottom": 70
  },
  "xAxis": {
    "axisLabel": {
      "formatter": "{value} ms",
      "color": "#475569"
    }
  },
  "yAxis": {
    "axisLabel": {
      "formatter": "{value}%",
      "color": "#475569"
    }
  },
  "series": [
    {
      "type": "scatter",
      "symbol": "diamond",
      "symbolSize": 90,
      "label": {
        "show": true,
        "color": "#0f172a",
        "formatter": "{b}"
      }
    }
  ]
}
