{
  "color": [
    "#5470c6",
    "#91cc75",
    "#fac858",
    "#ee6666",
    "#73c0de",
    "#3ba272",
    "#fc8452",
    "#9a60b4",
    "#ea7ccc"
  ],
  "backgroundColor": "#ffffff",
  "title": {
    "left": "left",
    "textStyle": {
      "fontSize": 26,
      "fontWeight": "bold",
      "color": "#1f2937"
    },
    "subtextStyle": {
      "fontSize": 11,
      "color": "#6b7280"
    }
  },
  "legend": {
    "show": true,
    "top": "top",
    "left": "left",
    "orient": "horizontal",
    "textStyle": {
      "fontSize": 11,
      "color": "#4b5563"
    }
  },
  "grid": {
    "left": 80,
    "right": 60,
    "top": 90,
    "bottom": 70
  },
  "xAxis": {
    "type": "value",
    "axisLabel": {
      "rotate": 0,
      "fontSize": 11,
      "color": "#4b5563"
    },
    "axisLine": {
      "show": true,
      "lineStyle": {
        "color": "#9ca3af"
      }
    },
    "splitLine": {
      "show": false
    }
  },
  "yAxis": {
    "type": "value",
    "axisLabel": {
      "fontSize": 11,
      "color": "#4b5563",
      "formatter": "{value}"
    },
    "axisLine": {
      "show": false
    },
    "splitLine": {
      "show": true,
      "lineStyle": {
        "color": "#e5e7eb",
        "type": "--",
        "width": 0.8
      }
    }
  },
  "series": [
    {
      "type": "scatter",
      "symbol": "circle",
      "symbolSize": 64,
      "label": {
        "show": false
      }
    }
  ]
}
